{
  "name": "@melody-sync/server",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "melodysync": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "build": "bun build src/server.ts --outdir dist --target bun && bun build src/cli.ts --compile --outfile dist/melodysync",
    "typecheck": "tsc --noEmit",
    "test": "bun test src/__tests__"
  },
  "dependencies": {
    "@melody-sync/types": "workspace:*",
    "commander": "^12.1.0",
    "croner": "^10.0.1",
    "hono": "^4.6.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ws": "^8.5.13",
    "typescript": "^5.6.0"
  }
}
